server {
    listen {{ nginx_port | default(80) }};
    server_name {{ nginx_server_name | default(inventory_hostname ~ '.' ~ lab_domain) }};
    root {{ nginx_document_root }};
    index index.html;

    location /health {
        return 200 "{{ inventory_hostname }} ok\n";
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
