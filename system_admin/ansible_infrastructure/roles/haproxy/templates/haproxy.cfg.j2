global
    log /dev/log local0
    maxconn 2048

defaults
    mode http
    timeout connect 5s
    timeout client 30s
    timeout server 30s

frontend http_front
    bind *:{{ haproxy_frontend_port | default(8080) }}
    default_backend web_backends

backend web_backends
    balance roundrobin
{% for host in groups['webservers'] %}
    server {{ host }} {{ host }}:{{ hostvars[host].nginx_port | default(80) }} check
{% endfor %}

listen stats
    bind *:{{ haproxy_stats_port }}
    stats enable
    stats uri /stats
